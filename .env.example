# GLOBAL ORBIT MAIL — Environment Template

NEXT_PUBLIC_APP_NAME="GLOBAL ORBIT MAIL"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_USER_PORTAL_URL="https://webmail.globalorbitmail.cloud"
NEXT_PUBLIC_ADMIN_PORTAL_URL="https://admin.theglobalorbit.com"
NEXT_PUBLIC_COMPANY_NAME="GLOBAL ORBIT PVT. LTD."

DATABASE_URL="postgresql://user:password@localhost:5432/global_orbit_mail?schema=public"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
# Auth enforcement for /orbit UI (API always checks session). Default: enforced unless "false".
ADMIN_AUTH_ENFORCE="true"
NEXT_PUBLIC_ENABLE_DARK_MODE="true"

# ── Mail / DNS (Phase 5A) ──────────────────────────────────────────
MAIL_HOSTNAME="mail.globalorbitmail.com"
WEBMAIL_HOSTNAME="webmail.globalorbitmail.cloud"
AUTOCONFIG_HOSTNAME="webmail.globalorbitmail.cloud"
# Production mail server IPv4 (required for DNS A records). Never use 0.0.0.0.
# If unset / placeholder, the app resolves MAIL_HOSTNAME automatically.
MAIL_SERVER_IPV4=""
# Optional IPv6 for mail AAAA
MAIL_SERVER_IPV6=""
# Optional ownership TXT in DNS wizard (orbit-domain-verification=…)
DNS_OWNERSHIP_VERIFICATION="false"

# Provision mode: local (app on VPS) | ssh (remote agent) | disabled
MAIL_PROVISION_MODE="local"
MAIL_AGENT_SCRIPT="/opt/global-orbit/bin/mail-agent.sh"

# SSH mode (when MAIL_PROVISION_MODE=ssh)
MAIL_PROVISION_SSH_HOST=""
MAIL_PROVISION_SSH_USER="root"
MAIL_PROVISION_SSH_PORT="22"
MAIL_PROVISION_SSH_KEY_PATH=""

# Health checks
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_URL=""
REDIS_REQUIRED="false"
POSTFIX_SMTP_PORT="25"
DOVECOT_IMAP_PORT="143"
RSPAMD_HOST="127.0.0.1"
RSPAMD_PORT="11334"
NGINX_HEALTH_HOST="127.0.0.1"
NGINX_HEALTH_PORT="80"
PHP_FPM_HOST="127.0.0.1"
PHP_FPM_PORT="9000"
WEBMAIL_HEALTH_URL="https://webmail.globalorbitmail.cloud"
