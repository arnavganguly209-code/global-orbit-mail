# GLOBAL ORBIT MAIL — Environment Template
# Copy to .env.local for local development. Never commit secrets.

# Application
NEXT_PUBLIC_APP_NAME="GLOBAL ORBIT MAIL"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_USER_PORTAL_URL="https://webmail.theglobalorbit.com"
NEXT_PUBLIC_ADMIN_PORTAL_URL="https://orbit.theglobalorbit.com"
NEXT_PUBLIC_COMPANY_NAME="GLOBAL ORBIT PVT. LTD."

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/global_orbit_mail?schema=public"

# NextAuth (architecture ready — configure before enabling auth)
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Feature flags
NEXT_PUBLIC_ENABLE_DARK_MODE="true"
