// GLOBAL ORBIT MAIL — Phase 2B Enterprise Schema
// PostgreSQL + Prisma. Soft deletes, UUID ids, full relations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  SUPER_ADMIN
  RESELLER
  CUSTOMER
  SUPPORT_STAFF
  MAILBOX_USER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum OrganizationStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

enum OrganizationType {
  INTERNAL
  RESELLER
  CUSTOMER
}

enum DomainStatus {
  PENDING
  VERIFYING
  ACTIVE
  SUSPENDED
  FAILED
}

enum SslStatus {
  NONE
  PENDING
  ACTIVE
  EXPIRED
  FAILED
}

enum DnsStatus {
  UNKNOWN
  PENDING
  PARTIAL
  VERIFIED
  FAILED
}

enum MailStatus {
  DISABLED
  PROVISIONING
  ACTIVE
  SUSPENDED
  ERROR
}

enum MailboxStatus {
  ACTIVE
  SUSPENDED
  DISABLED
  PENDING
}

enum DnsRecordType {
  MX
  A
  AAAA
  TXT
  CNAME
  SPF
  DKIM
  DMARC
  PTR
}

enum DnsRecordStatus {
  PENDING
  VERIFIED
  MISSING
  MISMATCH
  EXPECTED
  DETECTED
}

enum VerificationKind {
  DOMAIN
  DNS_MX
  DNS_SPF
  DNS_DKIM
  DNS_DMARC
  SSL
  MAILBOX
}

enum VerificationState {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

model Organization {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  type      OrganizationType   @default(INTERNAL)
  status    OrganizationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?

  users         User[]
  domains       Domain[]
  mailboxes     Mailbox[]
  settings      SystemSetting[]
  notifications Notification[]
  activities    Activity[]
  verifications Verification[]
  subscriptions Subscription[]
  orders        Order[]
  invoices      Invoice[]

  @@index([deletedAt])
  @@map("organizations")
}

model Role {
  id          String     @id @default(uuid())
  key         SystemRole @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  username         String?    @unique
  name             String?
  image            String?
  passwordHash     String?
  status           UserStatus @default(INVITED)
  emailVerified    DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?
  roleId           String?
  organizationId   String?
  lastLoginAt      DateTime?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  role           Role?           @relation(fields: [roleId], references: [id], onDelete: SetNull)
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  accounts       Account[]
  sessions       Session[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  activities     Activity[]      @relation("ActivityActor")
  notifications  Notification[]
  subscriptions  Subscription[]  @relation("SubscriptionOwner")

  @@index([organizationId])
  @@index([roleId])
  @@index([status])
  @@index([deletedAt])
  @@index([lockedUntil])
  @@map("users")
}

/// Failed / successful login attempts for rate limiting & lockout (Phase 3A)
model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String?
  success   Boolean  @default(false)
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Domain {
  id             String       @id @default(uuid())
  name           String
  status         DomainStatus @default(PENDING)
  sslStatus      SslStatus    @default(NONE)
  dnsStatus      DnsStatus    @default(PENDING)
  mailStatus     MailStatus   @default(DISABLED)
  organizationId String
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mailboxes     Mailbox[]
  dnsRecords    DnsRecord[]
  verifications Verification[]

  @@unique([organizationId, name])
  @@index([status])
  @@index([name])
  @@index([deletedAt])
  @@map("domains")
}

model Mailbox {
  id             String        @id @default(uuid())
  localPart      String
  domainId       String
  organizationId String
  displayName    String?
  status         MailboxStatus @default(PENDING)
  passwordHash   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  domain       Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quota        MailboxQuota?
  aliases      Alias[]
  forwarders   Forwarder[]

  @@unique([localPart, domainId])
  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@map("mailboxes")
}

model MailboxQuota {
  id        String   @id @default(uuid())
  mailboxId String   @unique
  quotaMb   Int      @default(2048)
  usedMb    Int      @default(0)
  updatedAt DateTime @updatedAt

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@map("mailbox_quotas")
}

model Alias {
  id        String    @id @default(uuid())
  mailboxId String
  address   String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, address])
  @@index([deletedAt])
  @@map("aliases")
}

model Forwarder {
  id          String    @id @default(uuid())
  mailboxId   String
  destination String
  keepCopy    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([mailboxId])
  @@index([deletedAt])
  @@map("forwarders")
}

model DnsRecord {
  id        String          @id @default(uuid())
  domainId  String
  type      DnsRecordType
  name      String
  value     String          @db.Text
  priority  Int?
  status    DnsRecordStatus @default(PENDING)
  ttl       Int             @default(3600)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  deletedAt DateTime?

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId, type])
  @@index([status])
  @@index([deletedAt])
  @@map("dns_records")
}

model Verification {
  id             String            @id @default(uuid())
  kind           VerificationKind
  state          VerificationState @default(PENDING)
  organizationId String?
  domainId       String?
  target         String?
  detail         String?
  checkedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  domain       Domain?       @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([kind, state])
  @@index([domainId])
  @@map("verifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@map("audit_logs")
}

model Activity {
  id             String   @id @default(uuid())
  actorId        String?
  organizationId String?
  category       String
  message        String
  severity       String   @default("info")
  metadata       Json?
  createdAt      DateTime @default(now())

  actor        User?         @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([category])
  @@map("activities")
}

model Notification {
  id             String   @id @default(uuid())
  userId         String?
  organizationId String?
  title          String
  body           String
  read           Boolean  @default(false)
  href           String?
  createdAt      DateTime @default(now())

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model SystemSetting {
  id             String   @id @default(uuid())
  organizationId String?
  key            String
  value          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("system_settings")
}

enum PlanInterval {
  MONTHLY
  YEARLY
  TWO_YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

model Plan {
  id              String       @id @default(uuid())
  key             String       @unique
  name            String
  description     String?
  monthlyPriceUsd Decimal      @db.Decimal(10, 2)
  yearlyPriceUsd  Decimal?     @db.Decimal(10, 2)
  twoYearPriceUsd Decimal?     @db.Decimal(10, 2)
  storageGb       Int
  mailboxLimit    Int
  domainLimit     Int          @default(1)
  features        Json
  isPublic        Boolean      @default(true)
  contactSales    Boolean      @default(false)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id             String             @id @default(uuid())
  organizationId String
  ownerId        String?
  planId         String
  status         SubscriptionStatus @default(INCOMPLETE)
  interval       PlanInterval       @default(MONTHLY)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean        @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("SubscriptionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  plan         Plan         @relation(fields: [planId], references: [id])
  orders       Order[]
  invoices     Invoice[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
  @@map("subscriptions")
}

model Order {
  id             String      @id @default(uuid())
  organizationId String
  subscriptionId String?
  amountUsd      Decimal     @db.Decimal(10, 2)
  currency       String      @default("USD")
  status         OrderStatus @default(PENDING)
  provider       String      @default("manual")
  providerRef    String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@map("orders")
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  subscriptionId String?
  number         String        @unique
  amountUsd      Decimal       @db.Decimal(10, 2)
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime      @default(now())
  paidAt         DateTime?
  pdfUrl         String?
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("invoices")
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  percentOff    Int?
  amountOffUsd  Decimal?  @db.Decimal(10, 2)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  maxRedemptions Int?
  createdAt     DateTime  @default(now())

  @@map("coupons")
}
